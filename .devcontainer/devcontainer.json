{
  "name": "Spring Boot + Thymeleaf (Alpine)",

  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "VARIANT": "17-alpine"
    }
  },

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "extensions": [
        "Extension Pack for Java",
        "vscjava.vscode-maven",
        "vscjava.vscode-spring-boot-dashboard",
        "vscjava.vscode-spring-initializr",
        "ms-vscode.makefile-tools",
        "Equim.statichtml",
        "Zignd.html-css-class-completion",
        "ecmel.vscode-html-css"
      ],
      "settings": {
        "java.server.launchMode": "Standard",
        "java.debug.settings.showHex": true,
        "java.compile.nullAnalysis.mode": "automatic",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "redhat.java",
        "[html]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "editor.fontSize": 14,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "files.trimTrailingWhitespace": true
      }
    }
  },

  "forwardPorts": [8080, 8443],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot Application",
      "onAutoForward": "notify"
    },
    "8443": {
      "label": "Spring Boot HTTPS",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.m2/repository,target=/root/.m2/repository,type=bind,consistency=cached"
  ],

  "remoteEnv": {
    "JAVA_TOOL_OPTIONS": "-Xmx2048m"
  }
}
